# ============================================================
# Maa Diaries — Environment Variables
# Copy this file to .env and fill in real values.
# ============================================================

# ── Supabase (Client-side) ──────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Resend (Serverless API only) ────────────────────────────
RESEND_API_KEY=re_your_api_key

# ── Email Address Routing (Serverless API only) ─────────────
INFO_EMAIL=info@maadiaries.com           # Feedback & review notifications
ORDERS_EMAIL=orders@maadiaries.com       # Order confirmations & admin alerts
DELIVERY_EMAIL=deliveryupdate@maadiaries.com  # Delivery status updates to customers
SUPPORT_EMAIL=support@maadiaries.com     # Sender display for feedback/review emails

# ── PayU India Gateway (Serverless API only) ────────────────
PAYU_MERCHANT_KEY=your_payu_merchant_key
PAYU_MERCHANT_SALT=your_payu_merchant_salt
PAYU_ENV=sandbox                          # sandbox | production

# ── App URLs ────────────────────────────────────────────────
BASE_URL=http://localhost:5173            # Production: https://maadiaries.com
ALLOWED_ORIGIN=http://localhost:5173      # Production: https://maadiaries.com
